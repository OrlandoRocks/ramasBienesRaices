# Webpack dev server (HMR) — use the same host you open in the browser.
# Fixes "WebSocket connection to ws://10.x.x.x:8080/ws failed" when using localhost or port forwarding.
WDS_SOCKET_HOST=localhost
WDS_SOCKET_PORT=8080

# Martin vector tiles (Option A: ?residential_id= on /lands/{z}/{x}/{y})
VUE_APP_MARTIN_URL=http://localhost:3030
